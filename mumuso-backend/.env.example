# ─── Server Configuration ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_BASE_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mumuso_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Tokens ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-long
REFRESH_TOKEN_EXPIRY=30d

# ─── QR Token ────────────────────────────────────────────────────────────────
QR_SECRET=your-qr-secret-min-32-chars-long
QR_SECRET_OLD=

# ─── SafePay Payment Gateway ─────────────────────────────────────────────────
SAFEPAY_API_KEY=
SAFEPAY_SECRET_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_BASE_URL=https://sandbox.api.getsafepay.com
SAFEPAY_MOCK_SCENARIO=SUCCESS

# ─── Stripe Payment Gateway (Test Mode for Demos) ───────────────────────────
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_MOCK_SCENARIO=SUCCESS

# ─── Firebase (Push Notifications) ──────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Twilio (SMS/OTP) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AWS Services ────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=noreply@mumuso.com
AWS_S3_BUCKET=mumuso-assets

# ─── Discount Configuration ──────────────────────────────────────────────────
DISCOUNT_MIN_PCT=5
DISCOUNT_MAX_PCT=20

# ─── Rate Limiting ───────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_ALLOWLIST=

# ─── Feature Flags ───────────────────────────────────────────────────────────
IP_ALLOWLIST_ENABLED=false

# ─── POS Demo API Key ────────────────────────────────────────────────────────
# API key for Mock POS Terminal demo interface
POS_DEMO_API_KEY=demo-pos-api-key-12345

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
